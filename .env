# --- LiveKit (self-hosted WebRTC SFU) ---
# Generate a strong secret (32+ chars). Used by backend to mint JWT tokens
# and by LiveKit Server to verify webhook signatures.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=1d9361c2dbb200ff7665a4ca74ce89c7e0d9140db7798e266c49307f4e19cf70
# URL clients (RN app, web viewers) use to reach LiveKit. Set to your laptop's
# LAN IP for phone-on-Wi-Fi demos, e.g. ws://192.168.1.42:7880.
LIVEKIT_URL=ws://192.168.1.2:7880

# --- Postgres ---
POSTGRES_USER=streaming
POSTGRES_PASSWORD=streaming
POSTGRES_DB=streaming_app

# --- Broadcaster (laptop Python worker — runs on host, see BROADCASTER.md) ---
BROADCAST_CAMERA_INDEX=0

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production
DATABASE_URL=                     # leave empty for default SQLite (host dev); docker-compose overrides this to postgres://postgres:5432/...
CORS_ORIGINS=*

# --- Rate limiter ---
RATELIMIT_STORAGE_URI=memory://   # use redis://... in prod
RATELIMIT_DEFAULT=1000 per hour

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
MINIO_SECURE=false                # MUST be true in production

# --- Media (Content Library) ---
MEDIA_PUBLIC_BUCKET=streaming-app-media-public
MEDIA_PRIVATE_BUCKET=streaming-app-media-private
MEDIA_MAX_SIZE_MB=100
MEDIA_ALLOWED_MIMETYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,video/ogg,audio/mpeg,audio/ogg,audio/wav
MEDIA_QUOTA_MB_PER_USER=1024
MEDIA_PRESIGNED_TTL_SECONDS=300
MEDIA_EXTRACT_METADATA=false      # Phase 2: enable Pillow thumbnail/dim extraction
